---
const year = new Date().getFullYear();
---

<footer
  class="mt-auto border-t border-border dark:border-border-dark bg-surface dark:bg-surface-dark"
>
  <div
    class="mx-auto flex max-w-5xl flex-col gap-4 px-6 py-10 text-sm text-muted md:flex-row md:items-center md:justify-between md:px-8"
  >
    <p>
      <span class="font-mono text-foreground dark:text-foreground-dark"
        >titipi.</span
      >
      <span class="mx-2 text-border dark:text-border-dark">·</span>
      Security &amp; code.
    </p>

    <p class="font-mono text-xs">
      © {year} titipi. Built with Astro &amp; Tailwind.
    </p>
  </div>
</footer>
