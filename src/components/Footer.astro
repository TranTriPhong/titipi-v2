---
const year = new Date().getFullYear();
---

<footer
  class="mt-auto border-t border-[#f4f4f5]/10 bg-[#222831] text-[#f4f4f5]"
>
  <div
    class="mx-auto flex max-w-5xl flex-col gap-4 px-6 py-10 text-sm text-[#f4f4f5]/70 md:flex-row md:items-center md:justify-between md:px-8"
  >
    <p>
      <span class="font-logo text-base font-bold text-white"
        >titipi<span class="text-accent">.</span></span
      >
      <span class="mx-2 text-[#f4f4f5]/20">·</span>
      Security &amp; code.
    </p>

    <p class="font-mono text-xs text-[#f4f4f5]/50">
      © {year} titipi. Built with Astro &amp; Tailwind.
    </p>
  </div>
</footer>
