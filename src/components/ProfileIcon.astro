---
interface Props {
  platform: "GitHub" | "LeetCode" | "TryHackMe" | "HackTheBox";
}

const { platform } = Astro.props;
---

{
  platform === "GitHub" && (
    <svg
      class="h-8 w-8 text-foreground dark:text-foreground-dark"
      viewBox="0 0 24 24"
      fill="currentColor"
      aria-hidden="true"
    >
      <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.082 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
    </svg>
  )
}

{
  platform === "LeetCode" && (
    <svg class="h-8 w-8" viewBox="0 0 24 24" aria-hidden="true">
      <rect width="24" height="24" rx="4" fill="#FFA116" />
      <text
        x="12"
        y="16"
        text-anchor="middle"
        fill="#000"
        font-family="Inter, sans-serif"
        font-size="9"
        font-weight="700">LC</text
      >
    </svg>
  )
}

{
  platform === "TryHackMe" && (
    <svg class="h-8 w-8" viewBox="0 0 24 24" aria-hidden="true">
      <rect width="24" height="24" rx="4" fill="#212C42" />
      <text
        x="12"
        y="15.5"
        text-anchor="middle"
        fill="#A3E635"
        font-family="JetBrains Mono, monospace"
        font-size="7.5"
        font-weight="700">THM</text
      >
    </svg>
  )
}

{
  platform === "HackTheBox" && (
    <svg class="h-8 w-8" viewBox="0 0 24 24" aria-hidden="true">
      <rect width="24" height="24" rx="4" fill="#111827" />
      <text
        x="12"
        y="15.5"
        text-anchor="middle"
        fill="#9FEF00"
        font-family="JetBrains Mono, monospace"
        font-size="7"
        font-weight="700">HTB</text
      >
    </svg>
  )
}
